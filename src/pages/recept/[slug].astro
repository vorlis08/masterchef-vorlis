---
import Layout from '../../layouts/Layout.astro';
import { recipes } from '../../data/recipes';

export function getStaticPaths() {
  return recipes.map(recipe => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const base = import.meta.env.BASE_URL;

const difficultyColor: Record<string, string> = {
  'Snadné': 'text-sage-400',
  'Střední': 'text-amber-400',
  'Náročné': 'text-red-400',
};
---

<Layout title={recipe.title} description={recipe.description}>
  <!-- Hero image -->
  <section class="relative h-[50vh] md:h-[60vh] overflow-hidden">
    <img
      src={recipe.image}
      alt={recipe.title}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-warm-950 via-warm-950/40 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-12 max-w-5xl mx-auto">
      <a
        href={base}
        class="inline-flex items-center gap-2 text-warm-400 hover:text-accent transition-colors mb-6 text-sm"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Zpět na recepty
      </a>
      <h1 class="font-[Playfair_Display] text-4xl md:text-6xl font-bold text-white mb-4 animate-fade-in-up">
        {recipe.title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 animate-fade-in-up stagger-1">
        <div class="flex items-center gap-2 glass px-4 py-2 rounded-full">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm text-warm-200">{recipe.time}</span>
        </div>
        <div class="flex items-center gap-2 glass px-4 py-2 rounded-full">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-sm text-warm-200">{recipe.servings} porcí</span>
        </div>
        <span class={`text-sm font-semibold ${difficultyColor[recipe.difficulty] || ''}`}>
          {recipe.difficulty}
        </span>
        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/20 text-accent">
          {recipe.category}
        </span>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <p class="text-warm-300 text-lg leading-relaxed mb-12 max-w-3xl animate-fade-in-up">
      {recipe.description}
    </p>

    <div class="grid md:grid-cols-[1fr_2fr] gap-12">
      <!-- Ingredients -->
      <div class="animate-fade-in-up stagger-1">
        <div class="sticky top-28">
          <h2 class="font-[Playfair_Display] text-2xl font-bold text-warm-100 mb-6 flex items-center gap-3">
            <span class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent text-lg">🥘</span>
            Ingredience
          </h2>
          <ul class="space-y-3" id="ingredient-list">
            {recipe.ingredients.map((ing: string, i: number) => (
              <li class="flex items-start gap-3 group cursor-pointer ingredient-item" data-index={i}>
                <span class="mt-1 w-5 h-5 rounded border-2 border-warm-600 group-hover:border-accent flex items-center justify-center transition-colors shrink-0 checkbox">
                  <svg class="w-3 h-3 text-accent opacity-0 check-icon transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-warm-300 group-hover:text-warm-100 transition-colors ingredient-text">{ing}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Steps -->
      <div class="animate-fade-in-up stagger-2">
        <h2 class="font-[Playfair_Display] text-2xl font-bold text-warm-100 mb-8 flex items-center gap-3">
          <span class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent text-lg">👨‍🍳</span>
          Postup
        </h2>
        <div class="space-y-8">
          {recipe.steps.map((step: string, i: number) => (
            <div class="flex gap-5 group">
              <div class="shrink-0">
                <div class="w-10 h-10 rounded-full bg-warm-800/80 border-2 border-warm-700/50 flex items-center justify-center font-[Playfair_Display] font-bold text-accent group-hover:bg-accent group-hover:text-white group-hover:border-accent transition-all duration-300">
                  {i + 1}
                </div>
                {i < recipe.steps.length - 1 && (
                  <div class="w-0.5 h-full bg-warm-800/50 mx-auto mt-2" />
                )}
              </div>
              <div class="pb-8">
                <p class="text-warm-200 leading-relaxed text-lg">{step}</p>
              </div>
            </div>
          ))}
        </div>

        {recipe.tip && (
          <div class="mt-8 p-6 rounded-2xl bg-accent/10 border border-accent/20">
            <p class="text-warm-200 leading-relaxed">
              <span class="font-bold text-accent">💡 Tip: </span>
              {recipe.tip}
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Tags -->
    <div class="mt-16 pt-8 border-t border-warm-800/30">
      <div class="flex flex-wrap gap-3">
        {recipe.tags.map((tag: string) => (
          <span class="tag px-4 py-2 rounded-full text-sm bg-warm-800/40 text-warm-400 border border-warm-700/20 hover:border-accent/40 hover:text-accent cursor-default">
            #{tag}
          </span>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.ingredient-item').forEach(item => {
    item.addEventListener('click', () => {
      const checkbox = item.querySelector('.checkbox') as HTMLElement;
      const check = item.querySelector('.check-icon') as HTMLElement;
      const text = item.querySelector('.ingredient-text') as HTMLElement;

      const isChecked = check.style.opacity === '1';
      check.style.opacity = isChecked ? '0' : '1';
      checkbox.classList.toggle('border-accent', !isChecked);
      checkbox.classList.toggle('bg-accent/20', !isChecked);
      text.classList.toggle('line-through', !isChecked);
      text.classList.toggle('text-warm-600', !isChecked);
    });
  });
</script>
