---
interface Props {
  slug: string;
  title: string;
  description: string;
  image: string;
  time: string;
  difficulty: string;
  category: string;
  tags: string[];
}

const { slug, title, description, image, time, difficulty, category, tags } = Astro.props;
const base = import.meta.env.BASE_URL;

const difficultyColor: Record<string, string> = {
  'Snadné': 'bg-sage-500/20 text-sage-300',
  'Střední': 'bg-amber-500/20 text-amber-300',
  'Náročné': 'bg-red-500/20 text-red-300',
};
---

<a href={`${base}recept/${slug}/`} class="recipe-card block rounded-2xl overflow-hidden bg-warm-900/60 border border-warm-800/40 group">
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-warm-950/80 via-transparent to-transparent" />
    <div class="absolute top-4 left-4 flex gap-2">
      <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent/90 text-white backdrop-blur-sm">
        {category}
      </span>
      <span class={`px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm ${difficultyColor[difficulty] || ''}`}>
        {difficulty}
      </span>
    </div>
    <div class="absolute bottom-4 right-4 flex items-center gap-1.5 glass px-3 py-1.5 rounded-full">
      <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="text-xs font-medium text-warm-200">{time}</span>
    </div>
  </div>
  <div class="p-6">
    <h3 class="font-[Playfair_Display] text-xl font-bold text-warm-100 mb-2 group-hover:text-accent transition-colors duration-300">
      {title}
    </h3>
    <p class="text-warm-400 text-sm leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 3).map(tag => (
        <span class="tag px-2.5 py-1 rounded-full text-xs bg-warm-800/60 text-warm-400 border border-warm-700/30">
          #{tag}
        </span>
      ))}
    </div>
  </div>
</a>
